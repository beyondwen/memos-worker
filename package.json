{
  "name": "memos-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "node scripts/e2e-smoke.js",
    "dev": "wrangler dev --local",
    "build:web": "cd web && npm run build",
    "build": "npm run build:web && wrangler deploy --dry-run --outdir dist",
    "deploy": "npm run build:web && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply memos-db --local",
    "db:migrate": "wrangler d1 migrations apply memos-db --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260520.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14",
    "wrangler": "^4.50.0"
  },
  "overrides": {
    "ws": "^8.20.1"
  }
}
